# Output directory for downloaded comics / 下载输出目录
OUTPUT_BASE=./output

# Number of images to download concurrently within a chapter / 章节内图片并发下载数
IMAGE_CONCURRENCY=2

# Delay in ms between image batch downloads (0 to disable) / 图片批次之间延迟，毫秒（0 则禁用）
DOWNLOAD_DELAY=3000

# Delay range in ms between chapters (simulates reading time) / 章节间延迟范围，毫秒（模拟阅读间隔）
CHAPTER_DELAY_MIN=5000
CHAPTER_DELAY_MAX=15000

# Custom User-Agent pool, one per line. Leave empty to use built-in defaults.
# 自定义 User-Agent 列表，每行一个。留空则使用内置默认值。
# USER_AGENTS=
